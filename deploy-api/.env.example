# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── GCP (optional for local dev) ─────────────────────────────
# Leave empty to run locally without GCP — in-memory storage is used automatically.
# Required only when deploying to Cloud Run with Firestore.
GCP_PROJECT_ID=

# Set to true to explicitly force in-memory mode (useful for testing)
USE_MEMORY_REPO=false

# RunPod Serverless Template ID (create at runpod.io → Serverless → Templates)
RUNPOD_TEMPLATE_ID=your-template-id

# Docker image for the inference worker
DOCKER_IMAGE=visgateai/inference:latest

# ── Internal webhook callback ────────────────────────────────
# Set to your Cloud Run service URL after first deploy
INTERNAL_WEBHOOK_BASE_URL=https://YOUR_SERVICE-hash-uc.a.run.app
INTERNAL_WEBHOOK_SECRET=change-me-strong-random-secret

# ── Firestore collection names ───────────────────────────────
FIRESTORE_COLLECTION_DEPLOYMENTS=visgate_deploy_api_deployments
FIRESTORE_COLLECTION_LOGS=visgate_deploy_api_logs
FIRESTORE_COLLECTION_API_KEYS=visgate_deploy_api_api_keys

# ── Optional: Platform HF Pro token ─────────────────────────
# Auto-injected when caller does not supply hf_token (enables gated model support)
# Store in GCP Secret Manager and reference with sm://VISGATE_DEPLOY_API_HF_PRO_ACCESS_TOKEN
VISGATE_DEPLOY_API_HF_PRO_ACCESS_TOKEN=

# ── Optional: Cloudflare R2 model cache ──────────────────────
# RW key — API-side only (future write-back). NEVER sent to RunPod workers.
VISGATE_DEPLOY_API_R2_ACCESS_KEY_ID_RW=
VISGATE_DEPLOY_API_R2_SECRET_ACCESS_KEY_RW=
# RO key — injected into RunPod workers for shared cache reads.
VISGATE_DEPLOY_API_R2_ACCESS_KEY_ID_R=
VISGATE_DEPLOY_API_R2_SECRET_ACCESS_KEY_R=
VISGATE_DEPLOY_API_S3_API_R2=            # https://ACCOUNT.r2.cloudflarestorage.com
VISGATE_DEPLOY_API_S3_MODEL_URL_R2=      # s3://visgate-models/models

SHARED_CACHE_ENABLED=true
SHARED_CACHE_ALLOWED_MODELS=stabilityai/sd-turbo,black-forest-labs/FLUX.1-schnell,stabilityai/stable-diffusion-xl-base-1.0,stabilityai/sdxl-turbo,stabilityai/stable-diffusion-3.5-large
SHARED_CACHE_REJECT_UNLISTED=true

# ── RunPod cost tuning ───────────────────────────────────────
# 0 = no idle GPU cost (cold start ~40-80s)
# 1 = one always-warm worker (~$0.35-0.80/hr idle per endpoint)
RUNPOD_WORKERS_MIN=0
RUNPOD_WORKERS_MAX=3
RUNPOD_IDLE_TIMEOUT_SECONDS=120
RUNPOD_DEFAULT_LOCATIONS=US

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
